    pipeline {
        agent any

        stages {
            stage('without-docker') {
                steps {
                    sh '''
                        echo "without docker"
                        ls -la
                        touch no-container.txt                   
                    '''
                }
            }

            stage('with-docker') {
                agent { 
                    docker {
                        image 'node:18-alpine'
                        reuseNode true
                    }
                }
                steps {
                    sh '''
                        echo "with docker"
                        ls -la
                        touch yes-container.txt
                        npm --version                        
                    '''
                }
            }
        }
    }